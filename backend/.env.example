# Copy this to .env and fill in your values

SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
NAME=
USER=
PASSWORD=
HOST=
PORT=

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_TIMEOUT_SECONDS=10
SEND_EMAIL_ASYNC=True

# Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=
BREVO_TIMEOUT_SECONDS=10
BREVO_EMAIL_URL=https://api.brevo.com/v3/smtp/email

# Check-in domain (used in QR codes)
CHECKIN_DOMAIN=https://yourdomain.com
RSVP_DOMAIN=https://yourdomain.com
MEDIA_BASE_URL=https://your-api-domain.com

# Termii
TERMII_API_KEY=
TERMII_SENDER_ID=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_TIMEOUT_SECONDS=10

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to True only if you need cookies/session auth across origins.
CORS_ALLOW_CREDENTIALS=False
